# ─── StayHeal Backend — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env with real secrets to source control.

# OpenWeatherMap API Key
# Get yours at: https://openweathermap.org/api
WEATHER_API_KEY=your_openweathermap_api_key_here

# Default city for weather lookups (OWM city name)
DEFAULT_CITY=Bengaluru

# The frontend origin to allow in CORS
# For production, set to your deployed frontend URL
FRONTEND_ORIGIN=http://localhost:3000
